{% if fiche.horaires is defined and fiche.horaires|length > 0 %}
    {% set days = ['Dimanche', 'Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'] %}
    <div class="mt-6">
        <h2 class="text-lg font-semibold text-slate-900">Horaires</h2>
        <div class="mt-3 overflow-hidden rounded-xl border border-slate-200 bg-white">
            <table class="w-full text-base">
                <tbody class="divide-y divide-slate-100">
                {% for schedule in fiche.horaires %}
                    <tr>
                        <td class="px-4 py-2.5 font-medium text-slate-700">
                            {{ days[schedule.day] ?? '' }}
                        </td>
                        <td class="px-4 py-2.5 text-slate-600">
                            {% if schedule.is_closed %}
                                <span class="text-red-500">Fermé</span>
                            {% elseif schedule.is_by_appointment %}
                                <span class="text-amber-600">Sur rendez-vous</span>
                            {% elseif schedule.morning_end is null and schedule.noon_start is null %}
                                {{ schedule.morningStart }}
                                {% if schedule.noonEnd %}- {{ schedule.noonEnd }}{% endif %}
                            {% else %}
                                {{ schedule.morningStart }}
                                {% if schedule.morningEnd %}- {{ schedule.morningEnd }}{% endif %}
                                {% if schedule.noon_start %}
                                    <span class="mx-1 text-slate-400">|</span>
                                    {{ schedule.noonStart }}
                                    {% if schedule.noonEnd %}- {{ schedule.noonEnd }}{% endif %}
                                {% endif %}
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}
