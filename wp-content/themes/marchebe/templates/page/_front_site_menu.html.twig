{% if menuItems|length > 0 %}
    <nav aria-label="Menu {{ title }}">
        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {% for item in menuItems %}
                <li>
                    <a href="{{ item.url }}"
                       class="group relative flex items-center gap-4 h-full overflow-hidden rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-offset-2"
                       style="--accent: var(--color-{{ site }}); --tw-ring-color: var(--color-{{ site }});">
                        <span class="absolute left-0 top-0 h-full w-1.5"
                              style="background-color: var(--accent);"></span>
                        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full"
                              style="background-color: color-mix(in srgb, var(--accent) 12%, white); color: var(--accent);">
                            <i class="fas fa-arrow-right transition-transform duration-200 group-hover:translate-x-1"
                               aria-hidden="true"></i>
                        </span>
                        <span class="text-lg font-semibold transition-colors duration-200"
                              style="color: var(--accent);">{{ item.title }}</span>
                    </a>
                </li>
            {% endfor %}
        </ul>
    </nav>
{% else %}
    <p class="text-center text-gray-400 py-8">Aucun élément de menu disponible.</p>
{% endif %}
